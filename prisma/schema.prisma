generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  User              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Announcement {
  id            String   @id
  title         String
  body          String
  attachmentUrl String?
  postedById    String
  createdAt     DateTime @default(now())
  updatedAt     DateTime
  User          User     @relation(fields: [postedById], references: [id])

  @@index([createdAt])
}

model AuditLog {
  id        String   @id
  userId    String
  action    String
  entity    String
  entityId  String
  metadata  Json?
  ipAddress String?
  createdAt DateTime @default(now())
  User      User     @relation(fields: [userId], references: [id])

  @@index([action])
  @@index([createdAt])
  @@index([entity, entityId])
  @@index([userId])
}

model Document {
  id           String           @id
  name         String
  url          String
  category     DocumentCategory
  fileSize     Int?
  uploadedById String
  createdAt    DateTime         @default(now())
  User         User             @relation(fields: [uploadedById], references: [id])

  @@index([category])
}

model Expense {
  id          String          @id
  amount      Float
  category    ExpenseCategory
  vendor      String?
  description String
  receiptUrl  String?
  expenseDate DateTime
  addedById   String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime
  User        User            @relation(fields: [addedById], references: [id])

  @@index([category])
  @@index([expenseDate])
}

model FeeSchedule {
  id        String    @id
  unitId    String
  amount    Float
  lateFee   Float     @default(0)
  monthYear String
  dueDate   DateTime
  createdAt DateTime  @default(now())
  updatedAt DateTime
  Unit      Unit      @relation(fields: [unitId], references: [id])
  Payment   Payment[]

  @@unique([unitId, monthYear])
  @@index([monthYear])
}

model Issue {
  id           String         @id
  unitId       String
  raisedById   String
  title        String
  description  String
  category     IssueCategory
  priority     IssuePriority  @default(MEDIUM)
  status       IssueStatus    @default(OPEN)
  assignedTo   String?
  photoUrls    String[]
  resolvedAt   DateTime?
  closedAt     DateTime?
  isEscalated  Boolean        @default(false)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime
  User         User           @relation(fields: [raisedById], references: [id])
  Unit         Unit           @relation(fields: [unitId], references: [id])
  IssueComment IssueComment[]

  @@index([category])
  @@index([status])
  @@index([unitId])
}

model IssueComment {
  id        String   @id
  issueId   String
  authorId  String
  text      String
  createdAt DateTime @default(now())
  User      User     @relation(fields: [authorId], references: [id])
  Issue     Issue    @relation(fields: [issueId], references: [id], onDelete: Cascade)

  @@index([issueId])
}

model Payment {
  id                     String        @id
  unitId                 String
  feeScheduleId          String
  amount                 Float
  lateFeeApplied         Float         @default(0)
  status                 PaymentStatus @default(PENDING)
  phonePeTxnId           String?       @unique
  phonePeMerchantOrderId String        @unique
  paymentMethod          String?
  paidAt                 DateTime?
  failureReason          String?
  receiptUrl             String?
  createdAt              DateTime      @default(now())
  updatedAt              DateTime
  FeeSchedule            FeeSchedule   @relation(fields: [feeScheduleId], references: [id])
  Unit                   Unit          @relation(fields: [unitId], references: [id])

  @@index([phonePeTxnId])
  @@index([status])
  @@index([unitId])
}

model Session {
  id           String   @id
  sessionToken String   @unique
  userId       String
  expires      DateTime
  User         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Unit {
  id          String        @id
  flatNumber  String        @unique
  block       String?
  floor       Int
  areaSqft    Float?
  ownerName   String?
  isOccupied  Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime
  FeeSchedule FeeSchedule[]
  Issue       Issue[]
  Payment     Payment[]
  User        User[]

  @@index([flatNumber])
}

model User {
  id            String         @id
  email         String         @unique
  name          String?
  phone         String?
  role          Role           @default(RESIDENT)
  unitId        String?
  isActive      Boolean        @default(false)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime
  image         String?
  emailVerified DateTime?
  Account       Account[]
  Announcement  Announcement[]
  AuditLog      AuditLog[]
  Document      Document[]
  Expense       Expense[]
  Issue         Issue[]
  IssueComment  IssueComment[]
  Session       Session[]
  Unit          Unit?          @relation(fields: [unitId], references: [id])

  @@index([email])
  @@index([unitId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum DocumentCategory {
  MEETING_MINUTES
  FINANCIAL_AUDIT
  MAINTENANCE_CONTRACT
  INVOICE
  OTHER
}

enum ExpenseCategory {
  REPAIRS
  UTILITIES
  SALARIES
  CLEANING
  SECURITY
  AMC
  MISCELLANEOUS
}

enum IssueCategory {
  ELECTRICAL
  PLUMBING
  LIFT
  COMMON_AREA
  SECURITY
  CLEANING
  OTHER
}

enum IssuePriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum IssueStatus {
  OPEN
  ASSIGNED
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum Role {
  SUPER_ADMIN
  PRESIDENT
  RESIDENT
}
